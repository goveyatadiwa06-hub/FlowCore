<div class="topbar">

  <!-- LEFT -->
  <div class="topbar-left">

    <!-- Drawer Toggle -->
    <button id="menuToggle" class="control-btn menu-btn" title="Menu">
      <i data-lucide="menu"></i>
    </button>

    <!-- Brand -->
    <div class="topbar-brand">
      <div class="brand-icon">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none"
             xmlns="http://www.w3.org/2000/svg">
          <rect x="3" y="6" width="18" height="12" rx="2"
                stroke="currentColor" stroke-width="2"/>
          <line x1="3" y1="10" x2="21" y2="10"
                stroke="currentColor" stroke-width="2"/>
        </svg>
      </div>
      <span class="brand-text">FlowCore</span>
    </div>

  </div>

  <!-- RIGHT -->
  <div class="topbar-right">

    <!-- Notifications -->
    <button class="control-btn" title="Notifications">
      <i data-lucide="bell"></i>
      <span class="notif-dot"></span>
    </button>

    <!-- Settings -->
    <a href="/settings" class="control-btn" title="Settings">
      <i data-lucide="settings"></i>
    </a>

    <!-- Avatar -->
    <div class="merchant-avatar" title="<%= merchantName %>">
      <%= merchantName ? merchantName.charAt(0).toUpperCase() : 'F' %>
    </div>

    <!-- Logout -->
    <form method="POST" action="/logout" class="logout-form">
      <button type="submit" class="control-btn logout" title="Logout">
        <i data-lucide="log-out"></i>
      </button>
    </form>

  </div>

</div>

<script>
  lucide.createIcons();
</script>
