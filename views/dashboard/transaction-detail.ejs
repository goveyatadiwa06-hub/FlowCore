<div class="page-container">
  <div class="transaction-container">

    <% if (!tx) { %>

      <div class="transaction-card">
        <div class="table-empty">
          Transaction not found.
        </div>
      </div>

    <% } else { %>

      <h2 class="transaction-title">Transaction Details</h2>

      <div class="transaction-card">

        <!-- Reference Block -->
        <div class="reference-block">
          <div class="reference-label">Transaction ID</div>
          <div class="reference-value"><%= tx.reference %></div>
        </div>

        <div class="divider"></div>

        <!-- Core Details Grid -->
        <div class="details-grid">

          <div class="label">Amount</div>
          <div class="value">
            $<%= Number(tx.amount || 0).toFixed(2) %>
          </div>

          <div class="label">Status</div>
          <div>
            <span class="status-badge status-<%= (tx.status || '').toLowerCase() %>">
              <%= (tx.status || '').toUpperCase() %>
            </span>
          </div>

          <div class="label">Phone</div>
          <div class="value">
            <%= tx.phone || '—' %>
          </div>

          <div class="label">Gateway Reference</div>
          <div class="value">
            <%= tx.gateway_reference || '—' %>
          </div>

          <div class="label">Description</div>
          <div class="value">
            <%= tx.description || '—' %>
          </div>

        </div>

        <div class="divider"></div>

        <!-- Metadata -->
        <div class="meta">
          <% 
            let createdFormatted = '';
            if (tx.created_at) {
              const createdDate = new Date(tx.created_at);
              if (!isNaN(createdDate)) {
                createdFormatted = createdDate.toLocaleString('en-ZW', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                });
              }
            }
          %>
          Created: <%= createdFormatted %>
        </div>

        <div class="divider"></div>

        <!-- Order Events -->
        <div class="events-section">
          <div class="events-title">Order Events</div>

          <% if (!events || events.length === 0) { %>

            <div class="events-empty">No events recorded.</div>

          <% } else { %>

            <div class="timeline">
              <% events.forEach(function(event) { %>

                <div class="timeline-item">
                  <div class="timeline-marker"></div>

                  <div class="timeline-content">
                    <div class="timeline-header">

                      <span class="timeline-state">
                        <%= (event.new_state || '').toUpperCase() %>
                      </span>

                      <span class="timeline-time">
                        <% 
                          let formattedDate = '';
                          if (event.created_at) {
                            const safeDate = new Date(event.created_at);
                            if (!isNaN(safeDate)) {
                              formattedDate = safeDate.toLocaleString('en-ZW', {
                                year: 'numeric',
                                month: 'short',
                                day: 'numeric',
                                hour: '2-digit',
                                minute: '2-digit'
                              });
                            }
                          }
                        %>
                        <%= formattedDate %>
                      </span>

                    </div>

                    <div class="timeline-meta">
                      Source: <%= event.source || 'system' %>
                      <% if (event.reason) { %>
                        • <%= event.reason %>
                      <% } %>
                    </div>

                  </div>
                </div>

              <% }) %>
            </div>

          <% } %>
        </div>

        <div class="divider"></div>

        <div class="detail-actions">
          <a href="/dashboard/transactions" class="btn btn-outline">
            Back to Transactions
          </a>
        </div>

      </div>

    <% } %>

  </div>
</div>