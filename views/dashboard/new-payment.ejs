<div class="page-container">
<div class="page-header">
    <div>
      <p class="page-subtext">
        Create a payment request and send it to your customer.
      </p>
    </div>
  </div>
  
  <div class="card form-card">
  
    <!-- PAYMENT INFO -->
    <div class="payment-info">
  
      <div class="info-row">
        <span>Business</span>
        <strong>
          <%= merchantName ? merchantName : '—' %>
        </strong>
      </div>
  
      <div class="info-row">
        <span>Reference</span>
        <strong>
          <%= reference || 'Not created yet' %>
        </strong>
      </div>
  
    </div>
  
    <% if (!reference) { %>
  
    <!-- CREATE PAYMENT FORM -->
    <form method="POST" action="/dashboard/new-payment" class="form-stack">
  
      <div class="form-group">
        <label>Customer Phone</label>
        <input
          type="tel"
          name="phone"
          placeholder="+2637XXXXXXXX"
          required
          inputmode="numeric"
          autocomplete="tel"
        />
      </div>
  
      <div class="form-group">
        <label>Amount (USD)</label>
        <input
          type="number"
          step="0.01"
          min="0.01"
          name="amount"
          placeholder="0.00"
          required
          inputmode="decimal"
        />
      </div>
  
      <div class="form-group">
        <label>Description (optional)</label>
        <input
          type="text"
          name="description"
          placeholder="Payment description"
          maxlength="120"
        />
      </div>
  
      <div class="button-stack">
        <button name="action" value="link" class="btn btn-primary btn-full">
          Create Payment Link
        </button>
  
        <button name="action" value="push" class="btn btn-outline btn-full">
          Send EcoCash Prompt
        </button>
      </div>
  
    </form>
  
    <% } else { %>
  
    <!-- PAYMENT CREATED -->
  
    <div class="success-box">
        <% if (action === 'push' && pushSent) { %>
            EcoCash prompt sent to customer
        <% } else { %>
            Payment link created successfully
        <% } %>
      </div>
      
      
    <div class="link-box">
      <input
        type="text"
        value="<%= paymentLink %>"
        id="paylink"
        readonly
      >
      <button type="button" class="btn btn-outline btn-full" onclick="copyLink()">
        Copy Link
      </button>
    </div>
  
    <div class="button-stack">
  
      <a
        href="https://wa.me/?text=<%= encodeURIComponent('Pay here: ' + paymentLink) %>"
        target="_blank"
        class="btn btn-outline btn-full"
      >
        Share via WhatsApp
      </a>
  
      <a href="/dashboard/new-payment" class="btn btn-outline btn-full">
        Create Another Payment
      </a>
  
    </div>
  
    <% } %>
  
  </div>
  
  <script>
  function copyLink() {
    const input = document.getElementById('paylink');
    if (!input) return;
    navigator.clipboard.writeText(input.value);
  }
  </script>
</div> 