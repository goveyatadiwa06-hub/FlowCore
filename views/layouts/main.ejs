<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title || 'FlowCore' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Inter font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- ICON LIBRARY (Lucide icons) -->
  <script src="https://unpkg.com/lucide@latest"></script>

  <!-- Main CSS -->
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<%
  const current = typeof active !== 'undefined' ? active : '';
  const merchant =
    typeof merchantName !== 'undefined' && merchantName
      ? merchantName
      : 'FlowCore Merchant';
%>

<div class="app">
  <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

  <!-- SIDEBAR -->
  <aside class="sidebar drawer" id="drawer">

    <div>
      <div class="sidebar-brand">
        <div class="brand-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none"
               xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="6" width="18" height="12" rx="2"
                  stroke="currentColor" stroke-width="2"/>
            <line x1="3" y1="10" x2="21" y2="10"
                  stroke="currentColor" stroke-width="2"/>
          </svg>
        </div>
        <span class="brand-text">FlowCore</span>
      </div>
      

      <nav class="sidebar-nav" aria-label="Main navigation">

        <a href="/dashboard" class="nav-link <%= current==='dashboard'?'active':'' %>">
          Dashboard
        </a>

        <a href="/dashboard/new-payment" class="nav-link <%= current==='create'?'active':'' %>">
          Initiate Payment
        </a>

        <a href="/dashboard/transactions" class="nav-link <%= current==='transactions'?'active':'' %>">
          Transaction History
        </a>

        <a href="/settings" class="nav-link <%= current==='settings'?'active':'' %>">
          Settings
        </a>

      </nav>
    </div>

    <div class="sidebar-footer">
      <span class="merchant"><%= merchant %></span>
      <span class="label">Merchant Account</span>
      
    </div>

  </aside>


  <!-- MAIN CONTENT -->
  <main class="main">

    <!-- TOP BAR -->
    <%- include('../partials/topbar') %>

    <!-- PAGE BODY -->
    <%- body %>

  </main>

</div>

<!-- activate icons -->
<script>
  lucide.createIcons();
</script>
<script>
  const sidebar = document.querySelector('.sidebar');
  const backdrop = document.getElementById('sidebarBackdrop');
  const toggle = document.getElementById('menuToggle');

  toggle.addEventListener('click', () => {
    sidebar.classList.toggle('open');
    backdrop.classList.toggle('active');
  });

  backdrop.addEventListener('click', () => {
    sidebar.classList.remove('open');
    backdrop.classList.remove('active');
  });
</script>

</body>
</html>
