<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= title || 'Email Verified' %> - FlowCore</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body class="login-body">

  <main class="login-container">

    <section class="login-card" aria-labelledby="verified-title">

      <header class="login-header">
        <h1 id="verified-title">FlowCore</h1>
        <p>Email verification</p>
      </header>

      <div class="alert success" role="alert" style="margin-bottom: 20px;">
        <strong>Email verified successfully</strong><br>
        Your account is now active.
      </div>

      <a href="/login" class="btn btn-primary btn-block">
        Proceed to Login
      </a>
    </section>

  </main>

</body>
</html>